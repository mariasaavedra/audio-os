{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",

    "strict": true,
    "noImplicitOverride": true,
    "noFallthroughCasesInSwitch": true,
    "forceConsistentCasingInFileNames": true,

    "esModuleInterop": true,
    "skipLibCheck": true,

    "paths": {
      "@m7/audio-os/feature/shell": ["./libs/feature/shell/src/index.ts"],
      "@m7/audio-os/feature/library": ["./libs/feature/library/src/index.ts"],
      "@m7/audio-os/feature/playback": ["./libs/feature/playback/src/index.ts"],
      "@m7/audio-os/feature/search": ["./libs/feature/search/src/index.ts"],

      "@m7/audio-os/ui/primitives": ["./libs/ui/primitives/src/index.ts"],
      "@m7/audio-os/ui/navigation": ["./libs/ui/navigation/src/index.ts"],
      "@m7/audio-os/ui/feedback": ["./libs/ui/feedback/src/index.ts"],

      "@m7/audio-os/shared/types": ["./libs/shared/types/src/index.ts"],
      "@m7/audio-os/shared/constants": ["./libs/shared/constants/src/index.ts"],
      "@m7/audio-os/shared/utils": ["./libs/shared/utils/src/index.ts"],

      "@m7/audio-os/mopidy": ["./libs/mopidy/src/index.ts"]
    }
  }
}
